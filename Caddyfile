{$DOMAIN} {
    encode zstd gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
    }

    @api path /api/*
    handle @api {
        reverse_proxy ulda-backend:8000
    }

    handle {
        reverse_proxy ulda-frontend:80
    }
}
